<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        id="@+id/loginFragment"
        android:name="com.mrdeveloper.coreisp.ui.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        id="@+id/dashboardFragment"
        android:name="com.mrdeveloper.coreisp.ui.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            id="@+id/action_dashboardFragment_to_billingFragment"
            app:destination="@id/billingFragment" />
    </fragment>

    <fragment
        id="@+id/billingFragment"
        android:name="com.mrdeveloper.coreisp.ui.BillingFragment"
        android:label="Billing"
        tools:layout="@layout/fragment_billing" />

</navigation>
